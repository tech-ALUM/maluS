# Sample reverse proxy with automatic HTTPS (Let's Encrypt).
# Run Caddy in front of the app; replace the hostname and run:
#   caddy run --config deploy/Caddyfile
malus.example.com {
    encode gzip
    reverse_proxy 127.0.0.1:8000
}

