# maluS configuration — copy to .env and fill in. NEVER commit a real .env.

# --- Database ---------------------------------------------------------------
# SQLite (default) lives on the container's /data volume, WAL mode.
MALUS_DB_URL=sqlite:////data/malus.db
# Postgres (same ORM): enable the `postgres` compose profile and use, e.g.:
# MALUS_DB_URL=postgresql+psycopg://malus:CHANGE_ME@db:5432/malus

# --- Secrets (generate strong values; never commit) -------------------------
# Session-cookie signing key.  Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
MALUS_SECRET_KEY=CHANGE_ME__generate_a_long_random_value

# --- First-run admin bootstrap ---------------------------------------------
# Created only when the user table is empty; forces a password change on first login.
MALUS_ADMIN_USER=admin
MALUS_ADMIN_PASSWORD=CHANGE_ME__temporary_password

# --- Reverse proxy (Caddy service) ------------------------------------------
# Public hostname; Caddy auto-provisions HTTPS for it. Point its DNS at this host.
MALUS_DOMAIN=malus.example.com

# --- Logging ----------------------------------------------------------------
MALUS_LOG_LEVEL=INFO

# --- AI reviewer ------------------------------------------------------------
# The default AI path is FREE: interactive Claude Code over the MCP server
# (docs/usage/ai-reviewer.md) — no key, no server-side model calls.
# The server-side engine below is PAID (billed at Anthropic API rates); leave unset.
# MALUS_AI_ENGINE=anthropic

# --- Postgres service (only when using the `postgres` profile) --------------
# POSTGRES_USER=malus
# POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_DB=malus
